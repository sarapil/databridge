{
  "name": "DB Import Field Mapping",
  "module": "Import Export",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "autoincrement",
  "autoname": "",
  "fields": [
    {
      "fieldname": "source_field",
      "fieldtype": "Data",
      "label": "Source Field",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "target_field",
      "fieldtype": "Data",
      "label": "Target Field",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "transform",
      "fieldtype": "Select",
      "options": "\nUppercase\nLowercase\nTitle Case\nDate Format\nNumber Format\nCustom",
      "label": "Transform",
      "in_list_view": 1
    },
    {
      "fieldname": "custom_transform",
      "fieldtype": "Code",
      "label": "Custom Transform (Python)",
      "depends_on": "eval:doc.transform=='Custom'"
    },
    {
      "fieldname": "default_value",
      "fieldtype": "Data",
      "label": "Default Value"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}