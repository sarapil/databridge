{
  "name": "DB Validation Rule",
  "module": "Data Integrity",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:rule_name",
  "fields": [
    {
      "fieldname": "rule_name",
      "fieldtype": "Data",
      "label": "Rule Name",
      "reqd": 1
    },
    {
      "fieldname": "target_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Target DocType",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "field_name",
      "fieldtype": "Data",
      "label": "Field Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "rule_type",
      "fieldtype": "Select",
      "options": "Required\nUnique\nFormat\nRange\nCustom",
      "label": "Rule Type",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "format_regex",
      "fieldtype": "Data",
      "label": "Format Regex",
      "depends_on": "eval:doc.rule_type=='Format'"
    },
    {
      "fieldname": "min_value",
      "fieldtype": "Float",
      "label": "Min Value",
      "depends_on": "eval:doc.rule_type=='Range'"
    },
    {
      "fieldname": "max_value",
      "fieldtype": "Float",
      "label": "Max Value",
      "depends_on": "eval:doc.rule_type=='Range'"
    },
    {
      "fieldname": "custom_validation",
      "fieldtype": "Code",
      "label": "Custom Validation (Python)",
      "depends_on": "eval:doc.rule_type=='Custom'"
    },
    {
      "fieldname": "error_message",
      "fieldtype": "Data",
      "label": "Error Message"
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}