{
  "name": "DB Transform Rule",
  "module": "Mapping",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:rule_name",
  "fields": [
    {
      "fieldname": "rule_name",
      "fieldtype": "Data",
      "label": "Rule Name",
      "reqd": 1
    },
    {
      "fieldname": "transform_type",
      "fieldtype": "Select",
      "options": "Value Map\nFormula\nLookup\nDefault\nConcat\nSplit\nDate Format",
      "label": "Transform Type",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "value_map_json",
      "fieldtype": "Code",
      "options": "JSON",
      "label": "Value Map",
      "depends_on": "eval:doc.transform_type=='Value Map'"
    },
    {
      "fieldname": "formula",
      "fieldtype": "Code",
      "label": "Formula",
      "depends_on": "eval:doc.transform_type=='Formula'"
    },
    {
      "fieldname": "lookup_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Lookup DocType",
      "depends_on": "eval:doc.transform_type=='Lookup'"
    },
    {
      "fieldname": "lookup_field",
      "fieldtype": "Data",
      "label": "Lookup Field",
      "depends_on": "eval:doc.transform_type=='Lookup'"
    },
    {
      "fieldname": "default_value",
      "fieldtype": "Data",
      "label": "Default Value",
      "depends_on": "eval:doc.transform_type=='Default'"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}