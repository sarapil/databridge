      "options": "\nNone\nUppercase\nLowercase\nDate Format\nCustom",
      "label": "Transform"
    },
    {
      "fieldname": "custom_formula",
      "fieldtype": "Code",
      "label": "Custom Formula"
    },
    {
      "fieldname": "required",
      "fieldtype": "Check",
      "label": "Required"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}