{
  "name": "DB Scheduler",
  "module": "Sync",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:task_name",
  "fields": [
    {
      "fieldname": "task_name",
      "fieldtype": "Data",
      "label": "Task Name",
      "reqd": 1
    },
    {
      "fieldname": "task_type",
      "fieldtype": "Select",
      "options": "Import\nExport\nSync\nMigration",
      "label": "Task Type",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Ref. DocType"
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "options": "reference_doctype",
      "label": "Ref. Name"
    },
    {
      "fieldname": "cron_expression",
      "fieldtype": "Data",
      "label": "Cron Expression"
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    },
    {
      "fieldname": "last_run",
      "fieldtype": "Datetime",
      "label": "Last Run",
      "read_only": 1
    },
    {
      "fieldname": "next_run",
      "fieldtype": "Datetime",
      "label": "Next Run",
      "read_only": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Active\nPaused\nCompleted",
      "label": "Status",
      "default": "Active"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}