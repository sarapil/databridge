{
  "name": "DB Sync Configuration",
  "module": "Sync",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:sync_name",
  "fields": [
    {
      "fieldname": "sync_name",
      "fieldtype": "Data",
      "label": "Sync Name",
      "reqd": 1
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    },
    {
      "fieldname": "direction",
      "fieldtype": "Select",
      "options": "Push\nPull\nBidirectional",
      "label": "Direction",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "source_connection",
      "fieldtype": "Link",
      "options": "DB Source Connection",
      "label": "Source Connection"
    },
    {
      "fieldname": "local_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Local DocType",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "remote_entity",
      "fieldtype": "Data",
      "label": "Remote Entity"
    },
    {
      "fieldname": "field_map",
      "fieldtype": "Link",
      "options": "DB Field Map",
      "label": "Field Map"
    },
    {
      "fieldname": "cb1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "sync_interval",
      "fieldtype": "Select",
      "options": "Every 5 Minutes\nEvery 15 Minutes\nHourly\nDaily\nWeekly",
      "label": "Sync Interval",
      "default": "Hourly"
    },
    {
      "fieldname": "last_sync",
      "fieldtype": "Datetime",
      "label": "Last Sync",
      "read_only": 1
    },
    {
      "fieldname": "next_sync",
      "fieldtype": "Datetime",
      "label": "Next Sync",
      "read_only": 1
    },
    {
      "fieldname": "sync_status",
      "fieldtype": "Select",
      "options": "Idle\nRunning\nError",
      "label": "Sync Status",
      "default": "Idle",
      "read_only": 1
    },
    {
      "fieldname": "sb_conflict",
      "fieldtype": "Section Break",
      "label": "Conflict Resolution"
    },
    {
      "fieldname": "conflict_strategy",
      "fieldtype": "Select",
      "options": "Local Wins\nRemote Wins\nNewer Wins\nManual",
      "label": "Conflict Strategy",
      "default": "Newer Wins"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}