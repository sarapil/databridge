{
  "name": "DB Migration Step",
  "module": "Migration",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "autoincrement",
  "autoname": "",
  "fields": [
    {
      "fieldname": "step_name",
      "fieldtype": "Data",
      "label": "Step Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "source_entity",
      "fieldtype": "Data",
      "label": "Source Entity",
      "in_list_view": 1
    },
    {
      "fieldname": "target_doctype",
      "fieldtype": "Link",
      "options": "DocType",
      "label": "Target DocType",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "field_map",
      "fieldtype": "Link",
      "options": "DB Field Map",
      "label": "Field Map"
    },
    {
      "fieldname": "order_index",
      "fieldtype": "Int",
      "label": "Order",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Pending\nRunning\nCompleted\nFailed\nSkipped",
      "label": "Status",
      "default": "Pending"
    },
    {
      "fieldname": "row_count",
      "fieldtype": "Int",
      "label": "Rows",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}