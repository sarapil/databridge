{
  "name": "DB Connector Plugin",
  "module": "Connectors",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "issingle": 0,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "naming_rule": "By fieldname",
  "autoname": "field:connector_name",
  "fields": [
    {
      "fieldname": "connector_name",
      "fieldtype": "Data",
      "label": "Connector Name",
      "reqd": 1
    },
    {
      "fieldname": "source_system",
      "fieldtype": "Select",
      "options": "Odoo\nQuickBooks\nSage\nTally\nSalesforce\nZoho\nCustom",
      "label": "Source System",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "connector_class",
      "fieldtype": "Data",
      "label": "Connector Class",
      "description": "Python dotted path"
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    },
    {
      "fieldname": "version",
      "fieldtype": "Data",
      "label": "Version"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "supported_entities",
      "fieldtype": "Code",
      "options": "JSON",
      "label": "Supported Entities"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "DB Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}